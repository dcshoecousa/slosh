# 应用基本配置
APP_NAME=FastAPI PG Template
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
VERSION=1.0.0

# 数据库配置
DATABASE_URL=postgresql+asyncpg://slosh:sloshpassword@127.0.0.1:5432/slosh_db

# 数据库表自动创建
AUTO_CREATE_TABLES=false

# Taskiq 配置
TASKIQ_ENABLED=false
TASKIQ_DATABASE_URL=postgresql://slosh:sloshpassword@127.0.0.1:5432/slosh_db
TASKIQ_KEEP_RESULTS=true
TASKIQ_MESSAGE_TABLE_NAME=taskiq_messages
TASKIQ_RESULT_TABLE_NAME=taskiq_results
TASKIQ_CHANNEL_NAME=taskiq
TASKIQ_POLL_INTERVAL_SECONDS=1.0

# JWT 认证配置
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 日志配置
LOG_LEVEL=INFO
LOG_JSON=false

# CORS 配置（多个值用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
